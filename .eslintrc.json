{
  "extends": [],
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "off"
  },
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "ignorePatterns": ["build/", "node_modules/", "dist/", "*.config.js"]
}

